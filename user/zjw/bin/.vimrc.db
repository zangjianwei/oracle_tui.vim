function! Addcolname(tabname, ...)
	"sil exec ":!crtcol.sh  ".a:tabname
	"sil exec "0 r "a:tabname.".col"
	if a:0 == 1
		exec "0 r !crtcol.sh ".a:tabname." \"".a:1."\""
		let b:cmd="1,$ !awk -v fgf=\"".a:1."\" -f ~/tbin/align.awk"
		exec b:cmd
		"1,$ !awk  -v fgf=a:1 -f ~/tbin/align.awk
	else
		exec "0 r !crtcol.sh ".a:tabname
		1,$ !awk  -v fgf="," -f ~/tbin/align.awk
	endif
endfun
command! -nargs=+ Addcolname call Addcolname(<f-args>)

