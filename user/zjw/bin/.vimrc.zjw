function! CheckFileChange()
    let current_content = join(getline(1, '$'), "\n")
    let file_content = join(readfile(expand('%')), "\n")
    
    if current_content !=# file_content
        " 自定义提示信息
        echohl WarningMsg
        echo "文件内容已被外部修改！"
        echohl None
        
        " 自动加载新内容
        "silent edit!
    endif
endfunction


function! GentleCheck()
    " 获取文件修改时间
    let current_mtime = getftime(expand('%'))
    if !exists('b:last_mtime')
        let b:last_mtime = current_mtime
        return
    endif
    
    " 如果文件已修改
    if current_mtime > b:last_mtime
        echohl WarningMsg
        echo "文件内容已被外部修改！请按:e刷新"
        echohl None
        
        " 可选：自动加载
        "silent edit!
        
        " 更新记录的时间
        let b:last_mtime = current_mtime
    endif
endfunction

