"生成一个表的调试日志
function! Addtrc(tabname)
    exec ". r !crttrc.sh ".a:tabname
endfun
command! -nargs=1 Addtrc call Addtrc(<f-args>)

func! Print(str)
	"前辍"a:"告诉Vim该变量是一个函数参数
	let mode="g/".a:str."/p"  
	echo mode
	"redir!>a1|sil exec mode|redir END "此处要用exec,否则只保存最后匹配行
endfun
command! -nargs=1 Pt call Print(<f-args>)  "或者下面定义
"command! -nargs=1 Pt redir!><args>|sil exec "g/".<args>."/p"|redir END 
"实现这种功能还有更简便的办法：g/mode/y A,将匹配行放入a寄存器

"使两个窗口同步滚动: set scrollbind (set scb)
"选项：'scrollopt' 'sbo' 设置同步滚动选项
"	    ver		'scrollbind' 窗口绑定垂直滚动
"	    hor		'scrollbind' 窗口绑定水平滚动

map  :w
map!  :w

map  "ay
"^[ 	]*[0-9A-Z_]\{3,\}*[ 	]*$

ab Row row_number() over(partition by subacct order by pageno desc, ordseq desc) as rowid1
ab Select select * from
ab Prev lag(bal) over(partition by acctno order by pageno,ordseq)
ab After lead(bal) over(partition by acctno order by pageno,ordseq)

function! Line()
    set cul
    set nowrap
	noremap <silent> [ zh
	noremap <silent> ] zl
	noremap <silent> { zH
	noremap <silent> } zL
endfun
command! Line call Line()

function! UnLine()
    set nocul
    set wrap
	unmap 9
	unmap 0
	unmap (
	unmap )
endfun
command! UnLine call UnLine()

function! AddnumA()
	1,$ s/^/\=printf("%5s ",line("."))
endfun
command! AddnumA call AddnumA()

function! Addnum() range
	let n = a:firstline
	let num = 1
	while n <= a:lastline
		let line = getline(n)
		let repl = substitute(line, '^', num.". ", "g")
		call setline(n, repl)
		let n = n + 1
		let num = num + 1
	endwhile
endfun
com! -range Addnum <line1>,<line2> call Addnum()

function! Addnum0(...) range
	let n = a:firstline
	let num = 1
	while n <= a:lastline
		let line = getline(n)
	    let nums=printf("%05d",num)
		if a:0 == 1
			let repl = substitute(line, '^', nums.a:1, "g")
		else
			let repl = substitute(line, '^', nums, "g")
		endif
		call setline(n, repl)
		let n = n + 1
		let num = num + 1
	endwhile
endfun
com! -nargs=? -range=% Addnum0 <line1>,<line2> call Addnum0(<f-args>)

"set enc=utf-8
"set tenc=gbk
function! Utf8() range
	set enc=utf-8
	set tenc=gbk
	"如果要保存成gbk,请设置fenc=gbk再保存
endfun
com! -nargs=? -range=% Utf8 <line1>,<line2> call Utf8(<f-args>)

function! Gbk() range
	set enc=gbk
	set tenc=utf-8
	"如果要保存成utf-8,请设置fenc=utf-8再保存
endfun
com! -nargs=? -range=% Gbk <line1>,<line2> call Gbk(<f-args>)

function! Unutf8() range
	unset enc=utf-8
	unset tenc=gbk
endfun
com! -nargs=? -range=% Unutf8 <line1>,<line2> call Unutf8(<f-args>)

function! AutoToUtf8() 
	if &fileencoding == 'utf-8'
		set enc=utf-8
		set tenc=gbk
	endif
endfun

fun! Checkin()
	let b:file=expand("%")
	execute  "!checkin ".b:file
endfun
com!  Checkin call Checkin()

