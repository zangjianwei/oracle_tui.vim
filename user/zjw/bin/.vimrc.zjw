function! AddnumA()
	1,$ s/^/\=printf("%5s ",line("."))
endfun
command! AddnumA call AddnumA()

function! Addnum() range
	let n = a:firstline
	let num = 1
	while n <= a:lastline
		let line = getline(n)
		let repl = substitute(line, '^', num.". ", "g")
		call setline(n, repl)
		let n = n + 1
		let num = num + 1
	endwhile
endfun
com! -range Addnum <line1>,<line2> call Addnum()

function! Addnum0(...) range
	let n = a:firstline
	let num = 1
	while n <= a:lastline
		let line = getline(n)
	    let nums=printf("%05d",num)
		if a:0 == 1
			let repl = substitute(line, '^', nums.a:1, "g")
		else
			let repl = substitute(line, '^', nums, "g")
		endif
		call setline(n, repl)
		let n = n + 1
		let num = num + 1
	endwhile
endfun
com! -nargs=? -range=% Addnum0 <line1>,<line2> call Addnum0(<f-args>)

