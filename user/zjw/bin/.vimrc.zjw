function! Demo()
    let lines = readfile(expand('%'))
    let data = []
    
    " 按行号循环
    for row in range(len(lines))
        let fields = split(lines[row], '|')
        let row_data = []
        
        " 按列号循环
        for col in range(len(fields))
            call add(row_data, fields[col])
        endfor
        
        call add(data, row_data)
    endfor
    
    " 访问示例
    echo "第1行第1列: " . data[0][0]
    echo "第1行第2列: " . data[0][1]
    echo "第2行第1列: " . data[1][0]
endfunction

autocmd BufNewFile,BufReadPost backlist nnoremap <buffer> OP :HelpBackList<CR>

" 函数：根据光标位置获取字段边界
function! GetFieldBoundaries(line, pos)
    " 获取传入的行字符串
    let l:line_content = a:line
    let l:pos = a:pos
    
    " 检查位置是否有效
    if l:pos < 1 || l:pos > len(l:line_content)
        echo "请将贯标放于字段位置"
        return {}
    endif
    
    " 检查字符是否为空格
	"echom "l:line_content=".l:line_content
	"echom "'l:pos=".l:pos
    if l:line_content[l:pos - 1] == ' '
        echoerr "Error: Position is on a space"
        return {}
    endif
    
    " 查找字段边界
    let l:start = l:pos
    let l:end = l:pos
    
    " 向左查找字段起始位置
    while l:start > 1 && l:line_content[l:start - 2] != ' '
        let l:start -= 1
    endwhile
    
    " 向右查找字段结束位置
    while l:end < len(l:line_content) && l:line_content[l:end] != ' '
        let l:end += 1
    endwhile
    
    return {'start': l:start, 'end': l:end}
endfunction

let g:last_cut_column = []

" 函数：按\x剪切当前光标所在的所有列
function! CutColumn()
    let l:col_data = []
    
    " 获取当前光标所在的列位置
    let l:cur_line = line('.')
    let l:cur_col = virtcol('.')
    let l:cur_line_text = getline(l:cur_line)
    let l:separator_text = getline(3)
    
    " 获取字段边界
    let l:boundary = GetFieldBoundaries(l:separator_text, l:cur_col)
    if empty(l:boundary)
        return
    endif
    
    " 计算数据行范围（第2行开始，直到遇到第一个空行）
    let l:start_line = 2
    let l:end_line = line('$')
    
    " 查找第一个空行
    for l:i in range(2, line('$'))
        if getline(l:i) == ''
            let l:end_line = l:i - 1
            break
        endif
    endfor
    
    " 从所有数据行提取对应列的内容
    for l:i in range(l:start_line, l:end_line)
        let l:line_text = getline(l:i)
        
        let l:col_content = strpart(l:line_text, l:boundary.start - 1, l:boundary.end - l:boundary.start + 1)
        call add(l:col_data, l:col_content)

		if l:boundary.start == 1
        	let l:new_line = strpart(l:line_text, l:boundary.end + 1)
		else
        	let l:new_line = strpart(l:line_text, 0, l:boundary.start - 1 -1) . 
                    \ strpart(l:line_text, l:boundary.end)
		endif
        call setline(l:i, l:new_line)
    endfor
    
    " 将列数据保存到全局变量
    let g:last_cut_column = l:col_data
endfunction

" 函数：按\p将刚才剪切的所有列复制到当前列后面
function! PasteColumn()
    if empty(g:last_cut_column) 
        echo "没有数据粘贴"
        return
    endif
    
    " 获取当前光标所在的列位置
    let l:cur_line = line('.')
    let l:cur_col = col('.')
    let l:cur_line_text = getline(l:cur_line)
    
    let l:separator_text = getline(3)

    " 获取当前列的字段边界
    let l:boundary = GetFieldBoundaries(l:separator_text , l:cur_col)
    if empty(l:boundary)
		return
    else
        let l:paste_pos = l:boundary.end 
    endif
	"echom "l:boundary.end=".l:boundary.end
    
    " 计算数据行范围（第2行开始，直到遇到第一个空行）
    let l:start_line = 2
    let l:end_line = line('$')
    
    " 查找第一个空行
    for l:i in range(2, line('$'))
        if getline(l:i) == ''
            let l:end_line = l:i - 1
            break
        endif
    endfor
    
    " 将剪切的数据粘贴到对应行
    for l:i in range(l:start_line, l:end_line)
        let l:line_idx = l:i - l:start_line
        let l:line_text = getline(l:i)
        
        " 插入剪切的列数据
        let l:col_content = g:last_cut_column[l:line_idx]
        let l:new_line = strpart(l:line_text, 0, l:paste_pos) . ' '.
                    \ l:col_content .
                    \ strpart(l:line_text, l:paste_pos)
        
        call setline(l:i, l:new_line)
    endfor
endfunction

" 设置快捷键映射
nnoremap <silent> \x :call CutColumn()<CR>
nnoremap <silent> \p :call PasteColumn()<CR>

