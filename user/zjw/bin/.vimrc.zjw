function! CheckCommand() abort
    let cmd = getcmdline()
    let type = getcmdtype()

    if type == ':' 
            if cmd =~# '^[ \t]*q[ \t]*$'
                let modified_cmd = 'qall'
                "call feedkeys(":\<C-U>" . modified_cmd . "\<CR>", 'n')
                "return ''
                return "\<C-U>pwd\<CR>"
            else
                return "\<CR>"
            endif
    endif
    
    "执行原始命令
    return "\<CR>"
endfunction
"cnoremap <silent> <buffer> <expr> <CR> CheckCommand()
                                                               
