    call setline(10, "")
    call setline(11, "已用时间:  00: 00: 00.01")
    
    echo "Test data created. You can now test the functions:"
    echo "- Move cursor to a column and press \x to cut it"
    echo "- Move cursor to another column and press \p to paste"
endfunction


