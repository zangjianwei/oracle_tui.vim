" 函数1: 获取当前光标所在的列号（兼容 Vim 7.4）
function! GetCurrentColumn()
    let line = getline('.')
    let col = col('.') - 1
    
    if col < 0
        return 0
    endif
    
    " 手动计算逗号数量（替代 count()）
    let before_cursor = strpart(line, 0, col)
    let comma_count = 0
    let i = 0
    while i < strlen(before_cursor)
        if before_cursor[i] == ','
            let comma_count += 1
        endif
        let i += 1
    endwhile
    
    echo comma_count + 1
endfunction

" 函数2: 跳到指定列的开始位置（兼容 Vim 7.4）
function! JumpToColumn(column)
    let line = getline('.')
    let col_num = a:column
    
    if col_num <= 1
        call cursor(line('.'), 1)
        return
    endif
    
    " 查找第 (col_num-1) 个逗号
    let comma_pos = -1
    let found = 0
    let i = 0
    
    while i < strlen(line)
        if line[i] == ','
            let found += 1
            if found == col_num - 1
                let comma_pos = i
                break
            endif
        endif
        let i += 1
    endwhile
    
    if comma_pos >= 0
        call cursor(line('.'), comma_pos + 2)
    else
        call cursor(line('.'), len(line) + 1)
    endif
endfunction

function! GetCurrentChar()
    let line = getline('.')
    let col_pos = col('.') - 1
    
    if col_pos >= strlen(line)
        return ''
    endif
    
    " 使用正则匹配当前字符（包括多字节）
    let before = strpart(line, 0, col_pos)
    let after = strpart(line, col_pos)
    
    " 匹配第一个字符（支持多字节）
    let char = matchstr(after, '^.')
	echo char
endfunction
